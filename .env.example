# ═══════════════════════════════════════════════════════════════════════
#  U2NyaWJl · Secretos          (U2NyaWJl = base64 de "Scribe")
#
#  Stack: GitHub Actions (cerebro) + Vercel (ingesta HTTP) + Apps Script
#         (despertador de Gmail).  Sin tarjeta, sin Firebase, sin Cloudflare.
#  Docker es solo el banco de trabajo local.
#
#  Guía paso a paso:  docs/SECRETS.md  ·  docs/secrets.html
#
#  REGLA: nunca un "# comentario" en la misma línea de una variable, nunca
#  comillas, nunca espacios alrededor del "=".
# ═══════════════════════════════════════════════════════════════════════

# ─── [LOCAL] Docker de desarrollo ────────────────────────────────────
HOST_UID=1000
HOST_GID=1000
TZ=America/Santiago
AGENT_NAME=U2NyaWJl
LOG_LEVEL=INFO

# ─── LISTO ✅ · VirusTotal ────────────────────────────────────────────
VIRUSTOTAL_API_KEY=
VT_UPLOAD_UNKNOWN=false
VT_UNKNOWN_POLICY=parse_flagged
MAX_FILE_SIZE_MB=25

# ─── LISTO ✅ · Dashboard ─────────────────────────────────────────────
DASHBOARD_API_TOKEN=
CORS_ALLOWED_ORIGINS=https://u2nyawjl.github.io,http://localhost:5173

# ─── LISTO ✅ · Gmail del agente ──────────────────────────────────────
GMAIL_ADDRESS=u2nyawjl@gmail.com
OWNER_EMAIL=nicoalvarezdiaz28@gmail.com
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=u2nyawjl@gmail.com
IMAP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=u2nyawjl@gmail.com
SMTP_PASSWORD=
# Solo los correos con esta etiqueta despiertan al agente al instante.
# El resto espera al latido diario.
GMAIL_WAKE_LABEL=agent-wake

# ─── LISTO ✅ · GitHub del agente ─────────────────────────────────────
GIT_AUTHOR_NAME=U2NyaWJl
GIT_AUTHOR_EMAIL=u2nyawjl@gmail.com
GITHUB_MODELS_TOKEN=
GITHUB_MODELS_BASE_URL=https://models.github.ai/inference
GITHUB_MODELS_MODEL=openai/gpt-4.1-mini
VAULT_REPO_OWNER=U2NyaWJl
VAULT_REPO_NAME=
VAULT_REPO_BRANCH=main
VAULT_GITHUB_TOKEN=

# ═══ [1] REPO DEL AGENTE (donde corren los GitHub Actions) ═══════════
# PÚBLICO: los minutos de Actions son ilimitados. Solo lleva código; los
# secretos van en GitHub Secrets y la bóveda es otro repo, privado.
AGENT_REPO_OWNER=U2NyaWJl
AGENT_REPO_NAME=ZW5naW5lCg-

# El cron real se define en el YAML del workflow (Actions no lo lee de env).
# Esto es solo la referencia: 12:00 UTC = 08:00 Santiago (UTC-4, invierno).
HEARTBEAT_UTC_HOUR=12
AGENT_MAX_LLM_CALLS_PER_HOUR=20

# ═══ [2] DESPERTADOR (Apps Script → Vercel → Actions) ════════════════
# TERCER PAT fine-grained · solo el repo del agente · Contents: Read and write
# Es lo que permite disparar un workflow con repository_dispatch.
GITHUB_DISPATCH_TOKEN=

# Secreto compartido: Apps Script lo manda en la cabecera y Vercel lo valida.
# Sin esto, cualquiera que descubra la URL puede despertar a tu agente a voluntad.
AGENT_WAKE_SECRET=

# URL pública de Vercel. Se rellena DESPUÉS del primer deploy.
PUBLIC_API_URL=

# ═══ [3] GOOGLE (Drive + Calendar) ═══════════════════════════════════
# Proyecto de Google Cloud SIN tarjeta: Blaze solo hacía falta para
# Cloud Functions, que ya no usamos. Ver docs/SECRETS.md.
# OAuth client tipo "Desktop app".
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Lo genera el script: python3 scripts/google_oauth.py
GOOGLE_OAUTH_REFRESH_TOKEN=
# Carpeta raíz del agente en Drive. La crea el script si no existe.
GDRIVE_ROOT_FOLDER_ID=
# Calendario donde el agente anota reuniones y eventos ("primary" = el suyo)
GOOGLE_CALENDAR_ID=primary

# ═══ [4] GITHUB ISSUES COMO SISTEMA DE TAREAS ════════════════════════
# El agente abre/comenta/cierra issues en el repo del agente. Notificaciones
# push gratis vía la app móvil de GitHub.
TASKS_VIA_ISSUES=true

# ═══ [5] WHATSAPP CLOUD API (META) ═══════════════════════════════════
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_OWNER_NUMBER=

# ═══ [6] HONEYPOT ════════════════════════════════════════════════════
HONEYPOT_ENABLED=true
